{
  "name": "omni-perception-mcp-server",
  "version": "1.0.0",
  "description": "MCP server exposing NVIDIA Nemotron 3 Nano Omni multimodal perception (image, audio, video, document) as composable MCP tools over stdio",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "omni-perception-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "openai": "^4.65.0",
    "zod": "^3.23.0",
    "pino": "^9.4.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.0.0"
  }
}
